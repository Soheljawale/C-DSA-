class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        

        int i = 0;
        int j = nums.size() -1;

        while( i <= j){
            if(nums[i] == 0){
                swap(nums[i], nums[j]);
                j--;
            }else if(nums[i] > nums[j]){
                swap(nums[i], nums[j]);
                i++;
            }else {
                i++;
            }
        }

    }
};
