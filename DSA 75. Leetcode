
// Leetcode 75. Sort Colors
// Pattern used Two Pointer


class Solution {
public:
    void sortColors(vector<int>& nums) {
        int i =0;
        int j = nums.size() - 1;
        int k = 0;
//time complexity : o(n)
//space complexity : o(1)
        while(k <= j){
            if(nums[k] == 1){
                k++;
            }else if(nums[k] == 2){
               swap(nums[k], nums[j]);
                j--;
            }else{
                swap(nums[k], nums[i]);
                k++;
                i++;
            }
        }
    }
};
